{
{{- if .work }}
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "/home/jerome/.config/fastfetch/sai.txt",
    "color": {
      "1": "37",
      "2": "36",
      "3": "34"
    }
  },
  "display": {
    "color": {
      "keys": "34",
      "title": "36"
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "de",
    "wm",
    "wmtheme",
    "theme",
    "icons",
    "font",
    "cursor",
    "terminal",
    "terminalfont",
    "cpu",
    "gpu",
    "memory",
    "swap",
    "disk",
    "localip",
    "battery",
    "poweradapter",
    "locale",
    "break",
    "colors"
  ]
{{- else }}
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "shell",
    "display",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "memory",
    "swap",
    {
      "type": "disk",
      "showRegular": true,
      "showExternal": false,
      "showHidden": false,
      "showSubvolumes": false,
      "showReadOnly": true,
      "showUnknown": false,
      "hideFolders": "/efi:/boot:/boot/*",
      "hideFS": "nfs:nfs4:cifs:smbfs:sshfs:davfs:fuse.sshfs",
      "useAvailable": false
    },
    "locale",
    "break",
    "colors"
  ]
{{- end }}
}
